generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Transaction {
  id        Int             @id @default(autoincrement())
  title     String
  amount    Decimal         @db.Decimal(12, 2)
  type      TransactionType
  createdAt DateTime        @default(now()) @map("created_at")

  @@map("transactions")
}

enum TransactionType {
  income
  expense
}