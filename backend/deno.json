{
  "tasks": {
    "dev": "deno run --watch --allow-net --allow-env --allow-sys --env-file=.env src/main.ts"
  },
  "imports": {
    "@hono/hono": "jsr:@hono/hono@^4.12.27",
    "@prisma/adapter-pg": "npm:@prisma/adapter-pg@7.8.0",
    "@prisma/client": "npm:@prisma/client@7.8.0",
    "@std/assert": "jsr:@std/assert@1",
    "dotenv": "npm:dotenv@^17.4.2",
    "prisma": "npm:prisma@^7.8.0"
  },
  "fmt": {
    "useTabs": false,
    "lineWidth": 80,
    "indentWidth": 4,
    "semiColons": false,
    "proseWrap": "preserve",
    "singleQuote": true
  }
}
